*~

# Any __pycache__ directories.
__pycache__/
__pycache__/*

# Macos-specific files.
.DS_Store

# Zone.Identifier files to be discarded.
*Zone.Identifier

# Cython generated files.
modules/*.c
modules/build/
modules/*.so

# Ignore build directory for docs
docs/build/*

# Ignore tutorials, experimental, testing folders
# The tutorials are now part of documentation
tutorials/*
testing/*
experimental/*